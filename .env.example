# GrokSearch 最小环境样例
# 最小主链只要求 GROK_API_URL / GROK_API_KEY。

GROK_API_URL=http://127.0.0.1:8000/v1
GROK_API_KEY=change-this-runtime-api-key
GROK_MODEL=grok-4.1-fast

# 最小交付建议先关闭 Tavily / Firecrawl，只验 Grok 上游搜索。
TAVILY_ENABLED=false
TAVILY_API_URL=https://api.tavily.com
TAVILY_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
FIRECRAWL_API_KEY=

GROK_DEBUG=false
GROK_LOG_LEVEL=INFO
GROK_LOG_DIR=logs
GROK_RETRY_MAX_ATTEMPTS=3
GROK_RETRY_MULTIPLIER=1
GROK_RETRY_MAX_WAIT=10

# 远程 HTTP MCP 服务
MCP_SERVER_API_KEY=change-this-mcp-api-key
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8765
MCP_SERVER_PATH=/mcp
MCP_SERVER_TRANSPORT=streamable-http
MCP_PUBLIC_BASE_URL=
MCP_READY_CHECKS=models,chat

# 网络代理隔离（可选）
# httpx 默认 trust_env=True，会自动读取以下变量。
# 当 MCP 子进程不希望被启动方（IDE / 客户端）的系统代理影响时，
# 在 MCP 配置 env 中显式置空，并设置 NO_PROXY=* 即可强制绕过。
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=
# NO_PROXY=
